# ── Required ──────────────────────────────────────────────────────────────────

# Path to your Obsidian vault directory (absolute path)
VAULT_DIR=/path/to/your/vault

# Path to the SQLite database file
DB_PATH=/path/to/tasks.db

# NextAuth.js secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# The public URL of the app (used for NextAuth callbacks and WebAuthn origin)
NEXTAUTH_URL=http://localhost:3000

# Single-user app password for credentials login
# Generate with: pnpm hash-password "your-password-here"
# IMPORTANT: wrap in double quotes — bcrypt hashes contain $ which dotenv misreads
APP_PASSWORD="bcrypt-hash-here"

# ── Optional ──────────────────────────────────────────────────────────────────

# Exposed port (default: 3000)
PORT=3000

# Path to store the registered passkey credential (default: VAULT_DIR/.passkey.json)
# PASSKEY_STORE_PATH=/path/to/.passkey.json

# Override vault subdirectory names if your vault uses different folder names
# Defaults shown — only set if your vault differs
# VAULT_DIR_INBOX=Inbox
# VAULT_DIR_PROJECTS=Projects
# VAULT_DIR_AREAS=Areas
# VAULT_DIR_CALENDAR=Calendar   # e.g. set to "Daily" if that's your daily notes folder
